.codex
.kuberlr
TODO.txt
.terraform/
# .terraform.lock.hcl records exact provider version selections and is safe to commit.
# HashiCorp recommends tracking it for reproducible builds. Remove this line if you
# want to pin provider versions across team members and CI.
.terraform.lock.hcl

# Large vendor artifacts
*.tar
*.tar.gz
*.tgz
*.img
*.iso

# Helm package output
*.tgz
*.prov

# Certificates, keys, and local secret material
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.truststore
*.csr
*.srl
# The chart's bundled dflt.crt / dflt.key are intentionally excluded.
# Terraform generates a fresh self-signed cert at apply time (tls.tf) and passes
# it to the chart via tls.existingSecret, so the bundled key is never used.

# License files
*.lic
*.license

# Terraform state files — contain plaintext secrets (license data, TLS keys,
# Helm values). Never commit. Use remote state (S3 + DynamoDB) for shared access.
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.backup
crash.log
crash.*.log
# Local override files — machine-specific, not for sharing
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local env and AWS credential helpers
.env
.env.*
*.local
*.local.yaml
*.local.yml
*.local.json

# Per-account variable files — contain account IDs, certificate ARNs, node names.
# Commit *.tfvars.example files as templates; keep actual values local.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Per-account backend configs (backends/*.hcl) contain only bucket/table names
# and are safe to commit — no exceptions needed here.

# kube and render output
*.kubeconfig
rendered-*.yaml
*.rendered.yaml
helm-template*.yaml

# OS and editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Python cache if helper scripts are used locally
__pycache__/
*.pyc
